{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortImports": {
    "internalPattern": ["@shared/*", "@entities/*", "@features/*", "@widgets/*", "@/*"],
    "groups": [
      "side_effect",
      "builtin",
      "external",
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "style",
      "unknown",
      "type"
    ],
    "newlinesBetween": true
  },
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    ".output/**",
    "src/routeTree.gen.ts"
  ]
}
